# =============================================================================
# OA-NSDIY Docker 环境变量配置模板
# =============================================================================
# 使用方式:
#   方式一(推荐): 运行部署脚本自动生成 .env 并填入随机密钥
#     cd deploy && bash docker-deploy.sh
#   方式二: 手动复制后修改
#     cp .env.example .env
#
# 修改完成后启动:
#   docker-compose up -d
#
# 变量会通过 docker-compose 的 env_file 注入容器进程环境，
# 应用通过 viper.AutomaticEnv() 读取 (key 中点号转下划线，并自动大写)。
# 仅在需要更复杂的配置时，才回退挂载 config.yaml (参考 config.example.yaml)。
#
# ── 必须修改的字段 ───────────────────────────────────────────────────────────
#   [必须修改]  生产环境上线前必须替换
#   [建议修改]  视部署环境调整，有合理默认值
#   [保持默认]  一般无需改动
# =============================================================================
#
# 快速自检清单:
#   [ ] JWT_SECRET          ← 必须替换为随机值 (openssl rand -hex 32)
#   [ ] IMAGE_REGISTRY      ← 远程拉取必填 (Gitee 容器仓库地址)
#   [ ] DATABASE_SOURCE     ← 切换到 PostgreSQL 时必填连接串
#   [ ] CORS_ALLOW_ORIGINS  ← 替换为真实前端域名
# =============================================================================

# -----------------------------------------------------------------------------
# 镜像仓库配置 (远程拉取模式必填)
# -----------------------------------------------------------------------------
# 远程镜像仓库地址 (不含镜像名/标签)。
# 本地构建模式留空即可 (compose 会回退到 build 块)。
# 示例:
#   Gitee 容器仓库:  registry.cn-hangzhou.aliyuncs.com/<命名空间>
#   Docker Hub:      docker.io/<用户名>
#   私有 Harbor:     harbor.example.com/<项目>
IMAGE_REGISTRY=
# 镜像标签 (留空默认 latest)
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
# 监听地址
SERVER_HOST=0.0.0.0
# 容器内服务端口 (一般无需改动；外部端口由 docker-compose 端口映射决定)
SERVER_PORT=3001
# 运行模式: release 或 debug (生产环境用 release)
SERVER_MODE=release
# 读写超时
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# 驱动: sqlite 或 postgres
DATABASE_DRIVER=sqlite
# SQLite: 文件路径，留空则自动推导为 /app/data/oa_nsdiy.db
# PostgreSQL: 连接串，例如
#   host=pg-host port=5432 user=pg-user password=pg-pass dbname=oa_nsdiy sslmode=require
DATABASE_SOURCE=

# -----------------------------------------------------------------------------
# Redis 配置 (预留，当前未实际使用)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT 认证配置
# -----------------------------------------------------------------------------
# [必须修改] 强随机密钥！生成命令: openssl rand -hex 32
# 注意: 修改后所有已签发的 token 会立即失效
JWT_SECRET=
# Access Token 有效期
JWT_ACCESS_EXPIRY=30m
# Refresh Token 有效期 (7天)
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别: debug / info / warn / error
LOG_LEVEL=info
# 日志格式: json 或 console
LOG_FORMAT=json
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=false
# 日志文件路径，留空则自动推导为 /app/data/logs/oa-nsdiy.log
LOG_OUTPUT_FILE_PATH=
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
# 日志中是否显示调用位置
LOG_CALLER=false
LOG_SERVICE_NAME=oa-nsdiy

# -----------------------------------------------------------------------------
# CORS 跨域配置
# -----------------------------------------------------------------------------
# 允许的前端来源，多个用英文逗号分隔 (例如: https://a.com,https://b.com)
# 单镜像同源部署时前后端同源，该项可保持默认或留空
CORS_ALLOW_ORIGINS=http://localhost:3000
# 允许的 HTTP 方法，多个用英文逗号分隔
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
# 允许的请求头，多个用英文逗号分隔
CORS_ALLOW_HEADERS=Content-Type,Authorization
# 是否允许携带凭证 (Cookie)
CORS_ALLOW_CREDENTIALS=true
