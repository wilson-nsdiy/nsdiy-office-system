# =============================================================================
# OA-NSDIY 环境变量配置模板
# =============================================================================
# 使用方式:
#   cp .env.example .env
#
# 配置通过 viper.AutomaticEnv() 读取 (key 中点号转下划线，并自动大写)。
#
# ── 必须修改的字段 ───────────────────────────────────────────────────────────
#   [必须修改]  生产环境上线前必须替换
#   [建议修改]  视部署环境调整，有合理默认值
#   [保持默认]  一般无需改动
# =============================================================================
#
# 快速自检清单:
#   [ ] JWT_SECRET          ← 必须替换为随机值 (openssl rand -hex 32)
#   [ ] DATABASE_SOURCE     ← 切换到 PostgreSQL 时必填连接串
#   [ ] CORS_ALLOW_ORIGINS  ← 替换为真实前端域名
# =============================================================================

# -----------------------------------------------------------------------------
# 数据目录配置
# -----------------------------------------------------------------------------
# 数据目录，用于存放数据库、日志、上传文件等
# 留空则默认为 ./data
DATA_DIR=

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
# 监听地址
SERVER_HOST=0.0.0.0
# 监听端口 (外部端口由部署环境决定)
SERVER_PORT=3001
# 运行模式:
#   - release: 生产模式，禁用调试信息，性能更好
#   - debug:   调试模式，启用详细错误信息，便于开发调试
SERVER_MODE=release
# 读写超时
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# 驱动: sqlite 或 postgres
DATABASE_DRIVER=sqlite
# 数据库连接源 (根据驱动填写):
#   - SQLite:    文件路径，留空则自动推导为 /app/data/db/oa_nsdiy.db
#               示例: /custom/path/data.db 或 ./local.db
#   - PostgreSQL: 连接串，格式:
#               host=<主机> port=<端口> user=<用户> password=<密码> dbname=<数据库名> sslmode=<模式>
#               示例: host=localhost port=5432 user=postgres password=secret dbname=oa_nsdiy sslmode=disable
DATABASE_SOURCE=

# -----------------------------------------------------------------------------
# Redis 配置 (预留，当前未实际使用)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT 认证配置
# -----------------------------------------------------------------------------
# [必须修改] JWT 签名密钥，用于生成和验证 Token
#   - 作用: 签发/验证 Access Token 和 Refresh Token
#   - 要求: 至少 32 字节的随机字符串，越长越安全
#   - 生成: openssl rand -hex 32 (生成 64 字符的十六进制字符串)
#   - 警告: 修改后所有已签发的 Token 会立即失效，用户需重新登录
JWT_SECRET=
# Access Token 有效期 (用户访问 API 时携带的短期 Token)
JWT_ACCESS_EXPIRY=30m
# Refresh Token 有效期 (用于刷新 Access Token 的长期 Token)
JWT_REFRESH_EXPIRY=168h

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别: debug / info / warn / error
LOG_LEVEL=info
# 日志格式: json 或 console
LOG_FORMAT=json
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=false
# 日志文件路径，留空则自动推导为 /app/data/logs/oa-nsdiy.log
LOG_OUTPUT_FILE_PATH=
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
# 日志中是否显示调用位置
LOG_CALLER=false
LOG_SERVICE_NAME=oa-nsdiy

# -----------------------------------------------------------------------------
# CORS 跨域配置
# -----------------------------------------------------------------------------
# 是否启用 CORS (单镜像同源部署时前后端同源，可关闭)
CORS_ENABLED=true
# 允许的前端来源，多个用英文逗号分隔 (例如: https://a.com,https://b.com)
CORS_ALLOW_ORIGINS=http://localhost:3000
# 允许的 HTTP 方法，多个用英文逗号分隔
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
# 允许的请求头，多个用英文逗号分隔
CORS_ALLOW_HEADERS=Content-Type,Authorization
# 是否允许携带凭证 (Cookie)
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# 上传文件配置
# -----------------------------------------------------------------------------
# 文件上传目录，留空则自动推导为 /app/data/uploads
UPLOAD_DIR=
